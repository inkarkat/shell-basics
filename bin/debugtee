#!/bin/bash

printShortUsage()
{
    # Note: short followed by long option; if the user knows the short one, she can
    # skim the long one.
    printf 'Usage: cat FILE [...] | %q %s | COMMAND ...\n' "$(basename "$1")" '[-1|--single-capture] [--no-header|-d|--description DESCRIPTION] [--for DEBUGGEE] [-m|--module MODULE] [--to FILE]'
    printf "Usage: cat FILE [...] | eval \"\${DEBUG:+%q %s |}\" 'COMMAND [...]'\\n" "$(basename "$1")" '...'
    printf "Usage: eval 'COMMAND [...]' \"\${DEBUG:+| %q %s}\"\\n" "$(basename "$1")" '... [--to ${HOME@Q}/out.log}]'
}
printUsage()
{
    # This is the short help when launched with no or incorrect arguments.
    # It is printed to stderr to avoid accidental processing.
    printShortUsage "$1" >&2
    printf >&2 '\nTry %q --help for more information.\n' "$(basename "$1")"
}
printLongUsage()
{
    # This is the long "man page" when launched with the help argument.
    # It is printed to stdout to allow paging with 'more'.
    cat <<HELPDESCRIPTION
Duplicate standard input to a debug file (DEBUGGEE.log) if debugging is enabled
for the debuggee, and print the debug filespec to standard error at the end.
$ DEBUG=DEBUGGEE[:MODULE] DEBUGGEE ...
$ DEBUG=debugtee=FILE,DEBUGGEE[:MODULE] DEBUGGEE ... will log to a custom
  FILE instead.
$ DEBUG=debugtee DEBUGGEE ... will show for what DEBUGGEE it will enable (if not
  actually enabled).
HELPDESCRIPTION
    echo
    printShortUsage "$1"
    echo
    cat <<HELPTEXT
    --single-capture|-1	Don't append to the debug file, but overwrite it with
			the latest capture. Disables the header, too.
    --no-header		Omit the header line with the timestamp (which is added
			by default).
    --description|-d DESCRIPTION
			Prepend DESCRIPTION to the timestamp in the header line.
    --for DEBUGGEE	Target DEBUGGEE; by default it will take the name of the
			parent process.
    --module|-m MODULE	Activate only if debugging for MODULE of the DEBUGGEE is
			enabled, and also debug into DEBUGGEE.log (unless
			overridden) instead of DEBUGGEE-MODULE.log, which would
			be the destination when passing --for DEBUGGEE:MODULE
			instead.
    --to FILE		Use FILE instead of the default debug file
			DEBUGGEE[-MODULE].log (unless overridden).
SEE ALSO:
- echotrace writes arguments as an execution trace to stderr instead of
  executing the passed command when debugging is enabled.
HELPTEXT
}

debuggee=
module=
debugteeFilespec=
isAppend=t
isHeader=t
description=
while [ $# -ne 0 ]
do
    case "$1" in
	--help|-h|-\?)	shift; printLongUsage "$0"; exit 0;;
	--single-capture|-1)
			shift; isAppend=;;
	--no-header)	shift; isHeader=;;
	--description|-d)
			shift; description="${1?}"; shift;;
	--for)		shift; debuggee="${1?}"; shift;;
	--module|-m)	shift; module="${1:?}"; shift;;
	--to)		shift; debugteeFilespec="${1:?}"; shift;;
	--)		shift; break;;
	-*)		{ echo "ERROR: Unknown option \"$1\"!"; echo; printUsage "$0"; } >&2; exit 2;;
	*)		break;;
    esac
done
if [ $# -ne 0 ]; then
    printUsage "$0" >&2
    exit 2
fi
[ ! "$isAppend" ] && [ -z "$description" ] && isHeader=	# Disable header if not appending and no description is given.

[ -n "$DEBUG" ] || exec cat

finally()
{
    if [ -s "$debugteeFilespec" ]; then
	printf >&2 "%sDebugtee'd to %q\\n" "$PS4" "$debugteeFilespec"
    elif [ -e "$debugteeFilespec" ]; then
	# Clean up an empty debug log.
	rm --force -- "$debugteeFilespec" || :
    fi
}

if [ -z "$debuggee" ]; then
    {
	IFS= read -r -d '' debugteeCmd
	IFS= read -r -d '' debugteeSecond
    } < /proc/${PPID}/cmdline
    debuggee="$(commandName --no-interpreter --undefined debugtee -- "$debugteeCmd" "$debugteeSecond")"
fi

case ",${DEBUG}," in
    *,${debuggee}${module:+:}${module},*)
	case ",${DEBUG}," in
	    *,debugtee=*,*) filespec=",${DEBUG},"; filespec="${filespec#*,debugtee=}"; filespec="${filespec%%,*}"
			    debugteeFilespec="$(realpath --no-symlinks -- "$filespec")" || debugteeFilespec="$filespec"
			    ;;
	    *)		    : ${debugteeFilespec:="${PWD}/${debuggee//:/-}.log"};;
	esac

	trap finally EXIT
	if [ "$isHeader" ]; then
	    isFirst=; [ ! "$isAppend" ] || [ ! -s "$debugteeFilespec" ] && isFirst=t;
	    eval 'HEADER_STYLE=dashed-line header ${isFirst:+--first} --no-color -- "${description}${description:+ at }$(timestamp --logging)"' ">${isAppend:+>} \"$debugteeFilespec\""
	    isAppend=t
	fi
	tee ${isAppend:+--append} -- "$debugteeFilespec"
	;;
    *,debugtee,*)
	printf >&2 'debugtee: Will activate with DEBUG=%q\n' "${debuggee}${module:+:}${module}"
	;&
    *)	exec cat
esac
