#!/bin/bash

printUsage()
{
    cat <<HELPTEXT
Log MESSAGE.
HELPTEXT
    echo
    printf 'Usage: %q %s\n' "$(basename "$1")" '[MESSAGE ...] [-?|-h|--help]'
}

case "$1" in
    --help|-h|-\?)	shift; printUsage "$0"; exit 0;;
esac

plainPrinter()
{
    printf '%s\n' "$*"
}

: ${LOG_TIMESTAMP_COMMAND=exec timestamp --logging --}
${LOG_TIMESTAMP_COMMAND:-plainPrinter} "$@"
