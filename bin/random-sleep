#!/bin/bash
shopt -qs extglob

printUsage()
{
    local timespanFormat="$(durationToSeconds --get-short-usage format 2>/dev/null)"
    cat <<HELPTEXT
Delay for a random amount of time between MAX and MIN.${timespanFormat:+
Format: }${timespanFormat}
HELPTEXT
    echo
    printf 'Usage: %q %s\n' "$(basename "$1")" '[MAX [MIN]] [-?|-h|--help]'
}

min=0
max=60
case "$1" in
    --help|-h|-\?)	shift; printUsage "$0"; exit 0;;
esac
case $# in
    0)	;;
    1)	max=$(durationToSeconds -- "${1:?}") || { printf >&2 'ERROR: Illegal TIMESPAN: %s\n' "$1"; exit 2; }; shift;;
    2)	max=$(durationToSeconds -- "${1:?}") || { printf >&2 'ERROR: Illegal TIMESPAN: %s\n' "$1"; exit 2; }; shift
	min=$(durationToSeconds -- "${1:?}") || { printf >&2 'ERROR: Illegal TIMESPAN: %s\n' "$1"; exit 2; }; shift
	if [ $max -lt $min ]; then
	    tmp=$max; max=$min; min=$tmp
	elif [ $max -eq $min ]; then
	    echo 'ERROR: MAX needs to be greater than MIN.'
	    echo
	    printUsage "$0"
	    exit 2
	fi >&2
	;;
    *)	printUsage "$0" >&2
	exit 2
	;;
esac

delay=$((min + RANDOM % (max - min)))
sleep "$delay"	# Don't use exec here so that we can observe this process in the process list.
