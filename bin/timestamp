#!/bin/bash

: ${TIMESTAMP_COMMAND_JOINER=;}
: ${TIMESTAMP_EXEC_END=;}

readonly FORMAT_DEFAULT='%d-%b-%Y${fieldSeparator- }%T${millis}'
readonly FORMAT_HUMAN='%d-%b-%Y${fieldSeparator-_}%T'
readonly FORMAT_SHORT='%Y%m%d${fieldSeparator--}%H%M%S'
readonly FORMAT_SORTABLE='%Y-%m-%d${fieldSeparator-T}%T${millis}'
readonly FORMAT_LOGGING='%Y-%m-%d${fieldSeparator- }%T${millis}'

printShortUsage()
{
    # Note: short followed by long option; if the user knows the short one, she can
    # skim the long one.
    printf 'Usage: %q %s\n' "$(basename "$1")" '[--human|--short|--sortable|--logging] [--no-millis] [-s|--separator SEP] [-F|--field-separator SEP] [-u|--utc|--universal] [-d|--date DATE] [--prefix PREFIX] [-?|-h|--help] ...'
    echo
    printf 'Usage: %q %s\n' "$(basename "$1")" '... [--quoted] [--] MESSAGE [...]'
    echo
    printf 'Usage: %q %s\n' "$(basename "$1")" "... [--static] -c|--command \"COMMANDLINE\" [-c ...] | --exec SIMPLECOMMAND ... $TIMESTAMP_EXEC_END [--exec ...]"
    echo
    printf 'Usage: cat FILE [...] | %q %s\n' "$(basename "$1")" '... [--static] -'
}
printUsage()
{
    # This is the short help when launched with no or incorrect arguments.
    # It is printed to stderr to avoid accidental processing.
    printShortUsage "$1" >&2
    printf >&2 '\nTry %q --help for more information.\n' "$(basename "$1")"
}
printLongUsage()
{
    # This is the long "man page" when launched with the help argument.
    # It is printed to stdout to allow paging with 'more'.
    cat <<HELPDESCRIPTION
Print a timestamp / prefix output from stdin with timestamps, by default as two
space-separated fields in a human-readable format that includes milliseconds.
HELPDESCRIPTION
    echo
    printShortUsage "$1"
    echo
    cat <<HELPTEXT
    --human		Human-readable output format: $FORMAT_HUMAN
    --short		Sortable output format: $FORMAT_SHORT
    --sortable		Sortable output format: $FORMAT_SORTABLE
    --logging		Format suitable for logging: $FORMAT_LOGGING
			Uses UTC time and appends 'Z' to the timestamp.
    --no-millis		Drop the milliseconds off the --sortable and --logging
			formats.
    --separator|-s SEP	Use SEP between timestamp and MESSAGE.
    --field-separator|-F SEP
			Use SEP between date and time.
    --utc|--universal|-u
			Use Coordinated Universal Time (UTC) instead of local
			time. Appends 'Z' to the timestamp.
    --date DATE		Use DATE instead of the current time.
    --prefix PREFIX	Put PREFIX directly before the timestamp.
    --quoted		Each argument of MESSAGE is individually quoted (e.g. to
			preserve a passed command with arguments in reusable
			form).
    --static		Do not update the timestamp for each line of input, but
			repeat the same timestamp (from when the first line was
			encountered) for all lines.
    --command|-c CMD	Execute CMD as a command-line and prefix its output.
    --exec COMMAND $TIMESTAMP_EXEC_END	Execute COMMAND; all following arguments are taken to be
			arguments to the COMMAND until an argument consisting of
			'${TIMESTAMP_EXEC_END}' is encountered. Its output is prefixed with
			timestamps.

RELATED COMMANDS:
- ts (provided by GNU moreutils)
- https://github.com/mislav/dotfiles/blob/master/bin/lineprof
HELPTEXT
}

typeset -a dateDateArgs=()
dateFormat="$FORMAT_DEFAULT"
dateFormatAppendix=
separator=' '
millis=',%3N'
unset fieldSeparator
isQuoted=
dateSourceInit=
dateSource=getDate
prefix=
commands=
while [ $# -ne 0 ]
do
    case "$1" in
	--help|-h|-\?)	shift; printLongUsage "$0"; exit 0;;
	--human)	shift; dateFormat="$FORMAT_HUMAN";;
	--short)	shift; dateFormat="$FORMAT_SHORT";;
	--sortable)	shift; dateFormat="$FORMAT_SORTABLE";;
	--logging)	shift; dateFormat="$FORMAT_LOGGING"; dateDateArgs+=(--utc); dateFormatAppendix='Z';;
	--no-millis)	shift; millis='';;
	--field-separator|-F)
			shift; fieldSeparator="$1"; shift;;
	--separator|-s)	shift; separator="$1"; shift;;
	--utc|--universal|-u)
			dateDateArgs+=("$1"); shift; dateFormatAppendix='Z';;
	--date|-d)	shift; dateDateArgs+=(--date "${1:?}"); shift;;
	--quoted)	shift; isQuoted=t;;
	--static)	shift; dateSourceInit=staticDateSourceInit; dateSource=getDateStatic;;
	--prefix)	shift; prefix="$1"; shift;;

	--command|-c)	shift; commands+="${commands:+ $TIMESTAMP_COMMAND_JOINER }$1"; shift;;
	--exec)		shift
			cmd=
			while [ $# -gt 0 -a "$1" != "$TIMESTAMP_EXEC_END" ]
			do
			    printf -v quotedArg '%q' "$1"
			    cmd+="${cmd:+ }${quotedArg}"
			    shift
			done
			if [ $# -eq 0 ]; then
			    echo "ERROR: --exec command must be concluded with '${TIMESTAMP_EXEC_END}'"; echo; printUsage "$0"
			    exit 2
			fi >&2
			shift
			commands+="${commands:+ $TIMESTAMP_COMMAND_JOINER }${cmd}"
			;;

	-)		break;;
	--)		shift; break;;
	-*)		{ echo "ERROR: Unknown option \"$1\"!"; echo; printUsage "$0"; } >&2; exit 2;;
	*)		break;;
    esac
done
[ -n "$NOW" -a ${#dateDateArgs[@]} -eq 0 ] && dateDateArgs=(--date "$NOW")

getDate()
{
    eval "date \"\${dateDateArgs[@]}\" \"+${dateFormat}${dateFormatAppendix}\""
}

staticDateSourceInit()
{
    : ${staticDate:="$(getDate)"}
}
getDateStatic()
{
    printf %s "${staticDate:?}"
}

timestampInput()
{
    local isEOL=t line
    while IFS=$'\n' read -r line || { isEOL=; [ -n "$line" ]; }
    do
	$dateSourceInit
	printf "%s%s%s%s${isEOL:+\\n}" "$prefix" "$($dateSource)" "$separator" "$line"
    done
}

if [ -n "$commands" ]; then
    if [ $# -ne 0 ]; then
	printUsage "$0" >&2
	exit 2
    fi

    eval "$commands" \
	| timestampInput
elif [ $# -eq 1 ] && [ "$1" = '-' ]; then
    timestampInput
elif [ $# -gt 0 ]; then
    if [ "$isQuoted" ]; then
	PRETTYPRINTQUOTEDARGS_PREFIX="${prefix}$(getDate)${separator}" \
	    exec prettyPrintQuotedArgs -- "$@"
    else
	printf '%s%s%s%s\n' "$prefix" "$(getDate)" "$separator" "$*"
    fi
else
    [ -n "$prefix" ] && printf %s "$prefix"
    getDate
fi
