#!/bin/bash

printUsage()
{
    cat <<HELPTEXT
Format and log ARG(s).
HELPTEXT
    echo
    printf 'Usage: %q %s\n' "$(basename "$1")" '[--prefix PREFIX [--prefix ...]] [--suffix SUFFIX [--suffix ...]] [--] FORMAT [ARG ...] [-?|-h|--help]'
}

prefix=
suffix=
while [ $# -ne 0 ]
do
    case "$1" in
	--help|-h|-\?)	shift; printUsage "$0"; exit 0;;
	--prefix|-p)	shift; prefix+="${1?}"; shift;;
	--suffix|-s)	shift; suffix="${1?}${suffix}"; shift;;
	--)		shift; break;;
	-*)		{ echo "ERROR: Unknown option \"$1\"!"; echo; printUsage "$0"; } >&2; exit 2;;
	*)		break;;
    esac
done

format="$1"; shift
printf -v message "$format" "$@"
exec log "${prefix}${message}${suffix}"
